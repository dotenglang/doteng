{
  "name": "@dotenglang/doteng",
  "version": "0.1.3",
  "description": "doteng — English as a Programming Language. Compile structured English to React, Laravel, HTML and more.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "doteng": "./bin/doteng.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
