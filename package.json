    "code-generator",
    "cli"
  ],
  "author": "Muhammad Ishmal Azmi",
  "license": "MIT",
  "homepage": "https://github.com/dotenglang/doteng",
  "repository": {
    "type": "git",
    "url": "https://github.com/dotenglang/doteng"
  },
  "files": [
    "bin/",
    "src/",
    "assets/",
    "templates/",
    "doteng.config.yaml",
    "LANGUAGE_SPEC.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
