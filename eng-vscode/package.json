{
  "name": "doteng-language",
  "displayName": "doteng Language Support",
  "description": "Syntax highlighting for .eng files (doteng — English as a Programming Language)",
  "version": "1.0.0",
  "publisher": "doteng",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0f0c29",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "eng",
        "aliases": ["ENG", "eng", ".eng", "doteng"],
        "extensions": [".eng"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "eng",
        "scopeName": "source.eng",
        "path": "./syntaxes/eng.tmLanguage.json"
      }
    ]
  }
}
